print("╚════════════════════════════════════════════════════════════╝")$
print("")$

/* Prueba L1: n=1 */
print("Prueba L1.1 - prof(1):")$
resultado_l1_1: prof(1)$
print(resultado_l1_1)$
print("¿Tiene 1 reina?:", is(length(resultado_l1_1) = 1))$
print("")$

print("Prueba L1.2 - profTodas(1):")$
resultado_l1_2: profTodas(1)$
print("Cantidad de soluciones:", length(resultado_l1_2))$
print(resultado_l1_2)$
print("¿1 solución?:", is(length(resultado_l1_2) = 1))$
print("")$

/* Prueba L2: n=2 */
print("Prueba L2.1 - prof(2):")$
resultado_l2_1: prof(2)$
print("Resultado:", resultado_l2_1)$
print("¿Es vacío (no hay solución)?:", is(resultado_l2_1 = []))$
print("")$

print("Prueba L2.2 - profTodas(2):")$
resultado_l2_2: profTodas(2)$
print("Cantidad de soluciones:", length(resultado_l2_2))$
print("¿0 soluciones (sin solución)?:", is(length(resultado_l2_2) = 0))$
print("")$

/* Prueba L3: n=3 */
print("Prueba L3.1 - prof(3):")$
resultado_l3_1: prof(3)$
print("Resultado:", resultado_l3_1)$
print("¿Es vacío (no hay solución)?:", is(resultado_l3_1 = []))$
print("")$

print("Prueba L3.2 - profTodas(3):")$
resultado_l3_2: profTodas(3)$
print("Cantidad de soluciones:", length(resultado_l3_2))$
print("¿0 soluciones?:", is(length(resultado_l3_2) = 0))$
print("")$

/* Prueba L4: n=4 - Caso ya probado */
print("Prueba L4.1 - profTodas(4):")$
resultado_l4_1: profTodas(4)$
print("Cantidad de soluciones:", length(resultado_l4_1))$
print("¿2 soluciones?:", is(length(resultado_l4_1) = 2))$
print("")$

/* Prueba L5: n=5 */
print("Prueba L5.1 - prof(5):")$
resultado_l5_1: prof(5)$
print("¿Tiene 5 reinas?:", is(length(resultado_l5_1) = 5))$
if (resultado_l5_1 # []) then (
    print("Solución encontrada:", resultado_l5_1),
    valido_l5: true,
    for i: 1 thru length(resultado_l5_1) do (
        for j: i+1 thru length(resultado_l5_1) do (
            r1: resultado_l5_1[i],
            r2: resultado_l5_1[j],
            if (r1[2] = r2[2] or abs(r1[1]-r2[1]) = abs(r1[2]-r2[2])) then
                valido_l5: false
        )
    ),
    print("¿Solución válida?:", valido_l5)
)$
print("")$

/* Prueba L6: n=5 todas las soluciones */
print("Prueba L5.2 - profTodas(5):")$
resultado_l5_2: profTodas(5)$
print("Cantidad de soluciones para n=5:", length(resultado_l5_2))$
print("¿Hay soluciones?:", length(resultado_l5_2) > 0)$
print("")$

