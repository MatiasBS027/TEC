/*  
Selection Sort 
*/

valorMinn(lsita):=block
(
    apply(min, lsita)
);

borrarElemento(ele, lista):= block
(
    delete(ele, lista, 1)
);

selectionSort(lista):= block
(   [minn, newLista]
    if lista = [] then  
        [],
    else (
        minn: valorMinn(lista),
        newLista: borrarElemento(minn, lista),
        cons(minn, selectionSort(newLista))
    )
)


/* Big Oh
