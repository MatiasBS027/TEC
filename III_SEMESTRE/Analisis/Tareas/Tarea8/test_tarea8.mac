/* Archivo de pruebas para Tarea8 - ejemplos de SPEC.md */

/* Ejemplo 1 */
grafo: [
  [c1, [[c2,10],[c3,15],[c4,20]]],
 [c2, [[c1,10],[c3,35],[c4,25]]],
 [c3, [[c1,15],[c2,35],[c4,30]]],
 [c4, [[c1,20],[c2,25],[c3,30]]]
];

print("Ejemplo 1 - tspPermu:");
print(tspPermu(c1, grafo));
print("Ejemplo 1 - tspGreedy:");
print(tspGreedy(c1, grafo));

