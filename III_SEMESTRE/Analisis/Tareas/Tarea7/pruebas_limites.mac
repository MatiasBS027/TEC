/* Prueba E1: conflicto con lista vacía */
print("Prueba E1.1 - conflicto([1,1], []):")$
resultado_e1_1: conflicto([1,1], [])$
print(resultado_e1_1)$
print("¿Correcto (false)?:", is(resultado_e1_1 = false))$
print("")$

