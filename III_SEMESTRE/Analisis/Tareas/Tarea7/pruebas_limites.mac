print("")$

print("✓ NÚMEROS NEGATIVOS:")$
if (is(resultado_n1_1 = []) and is(resultado_n2_1 = []) and
    is(resultado_n3_1 = [])) then
    print("  PASÓ - Números negativos handled correctamente")
else
    print("  FALLÓ")$
print("")$

print("✓ DETECCIÓN DE CONFLICTOS:")$
if (is(resultado_c1_1 = true) and is(resultado_c2_1 = true) and
    is(resultado_c3_1 = true) and is(resultado_c4_1 = false) and
    is(resultado_c5_1 = false) and is(resultado_c6_1 = true)) then
