print("✓ VALORES LÍMITE (n=0,1,2,3,4,5):")$
if (is(resultado_l1_1 = [[1,1]]) and is(length(resultado_l1_2) = 1) and
    is(resultado_l2_1 = []) and is(length(resultado_l2_2) = 0) and
    is(resultado_l3_1 = []) and is(length(resultado_l3_2) = 0) and
    is(length(resultado_l4_1) = 2) and length(resultado_l5_1) = 5) then
    print("  PASÓ - Todos los valores límite funcionan correctamente")
else
