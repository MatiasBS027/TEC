/* Prueba C1: Mismo conflicto de columna */
print("Prueba C1.1 - conflicto([2,1], [[1,1]]):")$
resultado_c1_1: conflicto([2,1], [[1,1]])$
print("¿Conflicto en columna?:", is(resultado_c1_1 = true))$
print("")$

/* Prueba C2: Conflicto diagonal izquierda */
print("Prueba C2.1 - conflicto([2,2], [[1,1]]):")$
resultado_c2_1: conflicto([2,2], [[1,1]])$
print("¿Conflicto diagonal?:", is(resultado_c2_1 = true))$
print("")$

/* Prueba C3: Conflicto diagonal derecha */
print("Prueba C3.1 - conflicto([3,3], [[1,1]]):")$
resultado_c3_1: conflicto([3,3], [[1,1]])$
print("¿Conflicto diagonal?:", is(resultado_c3_1 = true))$
print("")$

